{
  "permissions": {
    "allow": [
      "Read(*)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(npx tsc *)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(rg *)"
    ],
    "ask": [
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(npx supabase *)",
      "Edit(supabase/migrations/**)",
      "Edit(.env*)",
      "Edit(package.json)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Read(.env*)",
      "Read(**/.env*)",
      "Bash(cat .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(sed * .env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  }
}
