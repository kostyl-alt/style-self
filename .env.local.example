# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags
# 商品UI（商品候補・商品マッチング・ZOZO/楽天導線）の表示制御。既定 false。
# L2 で商品カタログを再投入する際に true へ。
NEXT_PUBLIC_PRODUCTS_ENABLED=false

# Knowledge OS（MCP 経由で診断の質を底上げ）
KNOWLEDGE_OS_URL=http://localhost:3001/api/mcp/rpc
KNOWLEDGE_OS_API_KEY=ko-sk-xxxx

# FASHN.ai（C-Phase1 着用イメージ生成・product-to-model）
# サーバー側のみ参照(クライアント露出なし)。規約: 24h 自動削除 + 訓練利用なし。
FASHN_API_KEY=fa-sk-xxxx
